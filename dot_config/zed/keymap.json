// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "bindings": {
      "f10": "collab::Mute",
    },
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "space f s": "file_finder::Toggle",
      "space f g": "workspace::NewSearch",
      "space e": "project_panel::ToggleFocus",
      "space a": "agent::ToggleFocus",
      "space b d": "pane::CloseActiveItem",
      "g r a": "editor::ToggleCodeActions",
      "space d d": "diagnostics::Deploy",
      "space l f": "editor::Format",
      "space t h": "workspace::ToggleLeftDock",
      "space t l": "workspace::ToggleRightDock",
      "space t m": "multi_workspace::ToggleWorkspaceSidebar"
    },
  },
]
