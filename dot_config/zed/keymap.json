// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "super-s": "workspace::Save",
    },
  },
  {
    "bindings": {
      "ctrl-cmd-shift-a": "agent::Toggle"
    }
  },
  {
    "context": "(Workspace && os == macos)",
    "bindings": {
      "ctrl-cmd-shift-t": "terminal_panel::Toggle"
    }
  },
  {
    "context": "Workspace && (os == macos)",
    "bindings": {
      "ctrl-cmd-shift-m": "multi_workspace::ToggleWorkspaceSidebar"
    }
  }
]
